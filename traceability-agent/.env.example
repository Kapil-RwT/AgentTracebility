# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_URL=https://grafana-k8s-ci.myntra.com
GRAFANA_TOKEN=your_grafana_token_here
# Datasource UID for Prometheus in Grafana.
# Find it: Grafana → Configuration → Data Sources → Prometheus → copy UID from URL.
GRAFANA_DATASOURCE_UID=your_datasource_uid_here

# ── LLM backend ──────────────────────────────────────────────────────────────
# "anthropic" (default, production) or "ollama" (local, free, for testing)
LLM_BACKEND=ollama

# Anthropic (used when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=<your_anthropic_api_key>
# claude-haiku-4-5-20251001 is fast and cheap; use claude-sonnet-4-6 for harder cases
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (used when LLM_BACKEND=ollama)
# 1. Install: https://ollama.com  2. Run: ollama serve  3. Pull: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b


# ── Cluster default ──────────────────────────────────────────────────────────
DEFAULT_CLUSTER=
